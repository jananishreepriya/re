import { configureStore, createSlice } from '@reduxjs/toolkit';
import { Provider, useSelector, useDispatch } from 'react-redux';
import { useState } from 'react';
import './App.css';

// ---------- Redux slice ----------
const tasksSlice = createSlice({
  name: 'tasks',
  initialState: [],
  reducers: {
    addTask: (state, action) => {
      state.push({ id: Date.now(), text: action.payload, done: false });
    },
    toggleTask: (state, action) => {
      const task = state.find(t => t.id === action.payload);
      if (task) task.done = !task.done;
    },
    deleteTask: (state, action) => {
      return state.filter(t => t.id !== action.payload);
    }
  }
});

// eslint-disable-next-line react-refresh/only-export-components
export const { addTask, toggleTask, deleteTask } = tasksSlice.actions;

// ---------- Redux store ----------
const store = configureStore({
  reducer: tasksSlice.reducer
});

// ---------- Task component ----------
function TaskApp() {
  const [input, setInput] = useState('');
  const tasks = useSelector(state => state);
  const dispatch = useDispatch();

  const handleAdd = () => {
    if (input.trim()) {
      dispatch(addTask(input.trim()));
      setInput('');
    }
  };

  return (
    <div className="app task-tracker">
      <h2>✅ Smart Task Tracker</h2>
      <div className="add-task">
        <input
          value={input}
          onChange={e => setInput(e.target.value)}
          placeholder="Enter a new task..."
          onKeyDown={e => e.key === 'Enter' && handleAdd()}
        />
        <button onClick={handleAdd}>Add</button>
      </div>

      <ul className="task-list">
        {tasks.map(task => (
          <li key={task.id}>
            <span
              onClick={() => dispatch(toggleTask(task.id))}
              style={{ textDecoration: task.done ? 'line-through' : 'none', cursor: 'pointer' }}
            >
              {task.text}
            </span>
            <button onClick={() => dispatch(deleteTask(task.id))}>✕</button>
          </li>
        ))}
      </ul>

      {tasks.length === 0 && <p className="empty">No tasks yet. Add one above!</p>}
    </div>
  );
}

// ---------- Wrap with Provider ----------
export default function App() {
  return (
    <Provider store={store}>
      <TaskApp />
    </Provider>
  );
}

