STYLE.css
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}
body {
  font-family: system-ui, 'Segoe UI', sans-serif;
  background: white;
  color: black;
  line-height: 1.5;
}
nav {
  background: black;
  color: white;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1rem 5%;
  position: sticky;
  top: 0;
  flex-wrap: wrap;
  gap: 1rem;
}

nav h2 {
  font-size: 1.5rem;
  font-weight: 500;
}
nav ul {
  list-style: none;
  display: flex;
  gap: 2rem;
  flex-wrap: wrap;
}

nav a {
  text-decoration: none;
  color: lightgray;
  font-weight: 500;
}

nav a:hover {
  color: gray;
}
.hero {
  min-height: 90vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  background: black;
  color: white;
  padding: 2rem;
}

.hero h1 {
  font-size: clamp(2.5rem, 8vw, 4rem);
  margin-bottom: 0.75rem;
}

.hero p {
  font-size: clamp(1.2rem, 4vw, 1.8rem);
  color: lightgray;
  margin-bottom: 2rem;
}

.hero button {
  background: dimgray;
  border: none;
  color: white;
  padding: 0.9rem 2.5rem;
  font-size: 1.2rem;
  border-radius: 40px;
  cursor: pointer;
}
.section {
  padding: 4rem 5%;
  max-width: 1280px;
  margin: 0 auto;
}

.section-title {
  font-size: clamp(2rem, 5vw, 2.8rem);
  text-align: center;
  margin-bottom: 3rem;
  color: black;
  font-weight: 600;
}
.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 2rem;
}

.card {
  background: white;
  border-radius: 24px;
  padding: 2rem 1.8rem;
  border: 1px solid lightgray;
}

.card h3 {
  font-size: 1.6rem;
  color: black;
  margin-bottom: 1rem;
  border-bottom: 2px solid lightgray;
  padding-bottom: 0.5rem;
}

.card p,
.card li {
  color: black;
  font-size: 1.1rem;
  margin-bottom: 0.5rem;
}
.card ul {
  list-style: disc;
  padding-left: 1.5rem;
}

footer {
  background: black;
  color: lightgray;
  text-align: center;
  padding: 2rem;
  border-top: 1px solid dimgray;
}
@media (max-width: 600px) {
  nav {
    flex-direction: column;
    text-align: center;
  }
  nav ul {
    justify-content: center;
    gap: 1.2rem;
  }
  .hero h1 {
    font-size: 2.5rem;
  }
  .card {
    padding: 1.5rem;
  }
  .section-title {
    margin-bottom: 2rem;
  }
}
