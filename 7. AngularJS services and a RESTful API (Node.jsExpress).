<!DOCTYPE html>
<html ng-app="hospitalApp">
<head>
  <title>Hospital Management System</title>
  <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>
  <style>
    body {
      margin: 0;
      background: lightgray;
