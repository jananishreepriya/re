import { useState, useEffect } from 'react';
import axios from 'axios';
import './App.css';

// Use environment variable for API URL (set later in deployment)
const API = import.meta.env.VITE_API_URL || 'http://localhost:5000';

function App() {
  const [name, setName] = useState('');
  const [phone, setPhone] = useState('');
  const [students, setStudents] = useState([]);

  useEffect(() => {
    const fetchStudents = async () => {
      try {
        const res = await axios.get(`${API}/users`);
        setStudents(res.data);
      } catch (err) {
        console.error('Failed to fetch students:', err);
      }
    };
    fetchStudents();
  }, []);

  const addStudent = async () => {
    if (!name.trim() || !phone.trim()) return;
    try {
      await axios.post(`${API}/add-user`, { name, phone });
      setName('');
      setPhone('');
      // Refresh list after adding
      const res = await axios.get(`${API}/users`);
      setStudents(res.data);
    } catch (err) {
      console.error('Failed to add student:', err);
      if (err.response) {
        alert(`Failed to add student: ${err.response.status} - ${JSON.stringify(err.response.data)}`);
      } else if (err.request) {
        alert('Failed to add student: No response from server');
      } else {
        alert('Failed to add student: ' + err.message);
      }
    }
  };

  const deleteStudent = async (id) => {
    try {
      await axios.delete(`${API}/delete-user/${id}`);
      const res = await axios.get(`${API}/users`);
      setStudents(res.data);
    } catch (err) {
      console.error('Failed to delete student:', err);
      alert('Failed to delete student. Please try again.');
    }
  };

  return (
    <div className="app">
      <div className="card">
        <h2>📝 Student Admission</h2>
        <div className="form">
          <input
            type="text"
            placeholder="Student Name"
            value={name}
            onChange={(e) => setName(e.target.value)}
          />
          <input
            type="text"
            placeholder="Phone Number"
            value={phone}
            onChange={(e) => setPhone(e.target.value)}
          />
          <button onClick={addStudent}>Add Student</button>
        </div>

        <h3>Admission Records</h3>
        {students.length === 0 ? (
          <p className="empty">No students yet. Add one above!</p>
        ) : (
          <ul className="student-list">
            {students.map((s) => (
              <li key={s.id}>
                <span>{s.name} – {s.phone}</span>
                <button onClick={() => deleteStudent(s.id)}>✕</button>
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>
  );
}

export default App;

